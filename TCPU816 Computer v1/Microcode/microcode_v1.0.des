.args 1
    ALU_EN | ALU_NAND
    CARRY_CLR
    CONST_OE_FF | MARL_L
    CONST_OE_FF | MARL_H
    ALU_EN | RAM_OE | MAR_SEL
    ALU_OE | RAM_WE | MAR_SEL
    CARRY_SET
    ALU_EN
    ALU_OE | MARL_L
    ALU_CLR | CARRY_CLR
    ALU_EN | RAM_OE | PC_COUNT
