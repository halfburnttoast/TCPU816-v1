    CONST_OE_FF | MARL_L
    CONST_OE_FF | MARL_H
    ALU_EN | RAM_OE | MAR_SEL
    ALU_OE | RAM_WE | MAR_SEL
    ALU_OE | MARL_L
    ALU_CLR | CARRY_CLR
    ALU_EN | RAM_OE | MAR_SEL
    ALU_OE | RF_WE | RF_IN_Y
.end



.begin JSR                      ; stores PC. Must PC_COUNT x2 on RTS)
.args 2    
    CONST_OE_FF | MARL_L            ; 0xFFFF->MAR
    CONST_OE_FF | MARL_H            ;  "
    ALU_EN | ALU_NAND               ; -1 -> ALU
    CARRY_CLR
    ALU_EN | RAM_OE | MAR_SEL       ; -1 + SPL -> ALU
    RAM_OE | MAR_SEL | MARL_L       ; SPL -> MARL
    RAM_WE | MAR_SEL | PCOUT_L      ; PCL -> RAM[SP]
    ALU_OE | MARL_L                 ; SPL-1 -> MARL
    CARRY_CLR
    RAM_WE | MAR_SEL | PCOUT_H      ; PCH -> RAM[SP-1]
    ALU_EN | CONST_OE_FF            ; SP-2 -> ALU
    CONST_OE_FF | MARL_L            ; 0xFFFF -> MAR
    ALU_OE | RAM_WE | MAR_SEL       ; ALU -> SPL
    RAM_OE | MARL_L | PC_COUNT
    RAM_OE | MARL_H | PC_COUNT
    JMP | MAR_SEL
.end


.begin RTS
.args 2     ; for alignment, no actual args used
    ALU_CLR | CARRY_SET
    CONST_OE_FF | MARL_L
    CONST_OE_FF | MARL_H
    RAM_OE | MAR_SEL | ALU_EN       ; SP + 1 -> ALU
    ALU_OE | MARL_L
    RAM_OE | MAR_SEL | RF_WE | RF_IN_TMP    ; PCH -> TMP
    CARRY_SET
    ALU_EN
    ALU_OE | MARL_L                 ; SP + 1 -> ALU
    RAM_OE | MAR_SEL | MARL_L       ; PCL -> MARL
    RF_OE | RF_OUT_TMP | MARL_H     ; PCH -> MARH
    JMP | MAR_SEL
    CONST_OE_FF | MARL_L | PC_COUNT ; PC++
    CONST_OE_FF | MARL_H | PC_COUNT ; PC++
    ALU_OE | RAM_WE | MAR_SEL       ; ALU -> SP
.end


.begin LDSA
.args 1
    CONST_OE_FF | MARL_L
    CONST_OE_FF | MARL_H
    ALU_CLR | CARRY_SET
    ALU_EN | RAM_OE | MAR_SEL
    ALU_EN | RAM_OE | PC_COUNT
    ALU_OE | MARL_L
    RAM_OE | MAR_SEL | RF_WE | RF_IN_A
    ALU_CLR | CARRY_CLR
    ALU_EN | RF_OE | RF_OUT_A
.end


